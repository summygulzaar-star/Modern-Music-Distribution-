rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Rules ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
        incoming().role in ['artist', 'label', 'admin'] && 
        incoming().walletBalance == 0 &&
        incoming().email == request.auth.token.email;
      allow update: if (isOwner(userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'profileImage'])) ||
        isAdmin() ||
        (isOwner(userId) && request.auth.token.email == "Admin@sk.ji"); // Auto-promotion escape hatch
    }

    // --- Artist/Label Rules ---
    match /artists/{artistId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(artistId) && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /labels/{labelId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(labelId) && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // --- Release Rules ---
    match /releases/{releaseId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
        incoming().userId == request.auth.uid &&
        incoming().status == 'pending';
        
      allow update: if isSignedIn() && (
        // Artist can update their own pending/needs correction releases
        (existing().userId == request.auth.uid && 
         existing().status in ['pending', 'correction'] &&
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'artist', 'genre', 'audioUrl', 'coverUrl', 'metadata'])) ||
        // Artist can request takedown
        (existing().userId == request.auth.uid &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
         incoming().status == 'takedown') ||
        // Admin can update everything (approve, reject, set ISRC/UPC)
        isAdmin()
      );
    }

    // --- Transaction Rules ---
    match /transactions/{transactionId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && 
        incoming().userId == request.auth.uid && 
        incoming().type == 'withdrawal' && 
        incoming().status == 'pending';
      allow update: if isAdmin();
    }

    // --- Admins Collection ---
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.token.email == "Admin@sk.ji");
    }
  }
}
